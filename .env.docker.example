# Copy this file to `.env.docker.local`, adjust secrets/API keys, then run:
#   docker compose --env-file .env.docker.local up --build

# Keep development for local Docker staging. Use production only after replacing
# all secrets, CORS origins, and deployment hardening settings.
APP_ENV=development

# Backend auth. Development may use the demo tokens below.
JWT_SECRET_KEY=change-me-in-production-please
API_AUTH_TOKENS_JSON={"demo-user-token":{"user_id":"demo-user","role":"user"},"other-user-token":{"user_id":"other-user","role":"user"},"demo-admin-token":{"user_id":"demo-admin","role":"admin"}}
API_HEALTHCHECK_TOKEN=demo-admin-token

# Browser origins allowed to call FastAPI.
API_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL container credentials.
POSTGRES_DB=ai_companion
POSTGRES_USER=postgres
POSTGRES_PASSWORD=docker-postgres-password

# Redis container.
REDIS_ENABLED=true
REDIS_DB=0

# Model providers. Fill these before testing real chat.
ACTIVE_LLM_PROVIDER=deepseek
ACTIVE_EMBEDDING_PROVIDER=openai_compatible
LLM_MODEL=Qwen/Qwen3-32B
EMBEDDING_MODEL=BAAI/bge-m3
VECTOR_DIMENSION=1024
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
ENABLE_RERANK=false
RERANK_API_KEY=
RERANK_BASE_URL=https://api.siliconflow.cn/v1/rerank
INSTALL_LOCAL_ML=false

# MCP/hospital integration. Keep disabled until you add real hospital MCP URLs
# and user credentials in the app.
MCP_ENABLED=false
MCP_TOKEN_ENCRYPTION_KEY=
MCP_TOKEN_ENCRYPTION_KEYS=
MCP_APPOINTMENT_TOOL_MAPPING={}
MCP_HOSPITAL_ALIASES={}

# Knowledge base jobs. Keep off for the first deployment smoke test.
AUTO_BOOTSTRAP_KNOWLEDGE_BASE=false
ENABLE_KB_SYNC_SCHEDULER=false
KB_SYNC_INTERVAL_HOURS=24
KB_SYNC_OFFICIAL_SOURCES=medlineplus,nhc,who

# Frontend build-time config.
VITE_API_BASE_URL=http://localhost:8000
VITE_API_AUTH_TOKEN=demo-admin-token
VITE_APP_ENV=development
