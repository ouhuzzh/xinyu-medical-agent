# Copy to `.env.docker.prod.local` on the server and fill real values.
# Do not commit `.env.docker.prod.local`.

APP_DOMAIN=medical.example.com
API_DOMAIN=api.medical.example.com
PUBLIC_API_BASE_URL=https://api.medical.example.com
API_CORS_ORIGINS=https://medical.example.com

APP_ENV=production
JWT_SECRET_KEY=replace-with-a-long-random-secret
CHECKPOINT_SIGNING_KEY=replace-with-a-different-long-random-secret
API_AUTH_TOKENS_JSON={}

POSTGRES_DB=ai_companion
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-db-password
REDIS_DB=0

ACTIVE_LLM_PROVIDER=deepseek
ACTIVE_EMBEDDING_PROVIDER=openai_compatible
LLM_MODEL=Qwen/Qwen3-32B
EMBEDDING_MODEL=BAAI/bge-m3
VECTOR_DIMENSION=1024
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
ENABLE_RERANK=false
RERANK_API_KEY=
RERANK_BASE_URL=https://api.siliconflow.cn/v1/rerank

# Keep false unless production really needs local HuggingFace embeddings.
# true installs torch/sentence-transformers/transformers and makes the image much larger.
INSTALL_LOCAL_ML=false

MCP_ENABLED=false
# Keep enabled in production if user memories are enabled; it protects both MCP tokens
# and user memory PII at rest.
USER_MEMORY_ENCRYPT_PII=true
MCP_TOKEN_ENCRYPTION_KEYS=replace-with-fernet-key-list
MCP_APPOINTMENT_TOOL_MAPPING={}
MCP_HOSPITAL_ALIASES={}

AUTO_BOOTSTRAP_KNOWLEDGE_BASE=false
ENABLE_KB_SYNC_SCHEDULER=false
KB_SYNC_INTERVAL_HOURS=24
KB_SYNC_OFFICIAL_SOURCES=medlineplus,nhc,who
