# Langfuse Observability (optional)
# Set LANGFUSE_ENABLED=true and provide your API keys to enable tracing.
# Get your keys from https://cloud.langfuse.com or your self-hosted instance.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3000

# Model providers
ACTIVE_LLM_PROVIDER=deepseek
ACTIVE_EMBEDDING_PROVIDER=openai_compatible
LLM_MODEL=Qwen/Qwen3-32B
EMBEDDING_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
LLM_TEMPERATURE=0
VECTOR_DIMENSION=1024
ENABLE_RERANK=true
RERANK_FETCH_K=12

# DeepSeek (OpenAI-compatible chat)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI / OpenAI-compatible embeddings
OPENAI_API_KEY=your-openai-compatible-api-key
OPENAI_BASE_URL=
OPENAI_ENABLE_THINKING=false
OPENAI_THINKING_BUDGET=1024
RERANK_API_KEY=
RERANK_BASE_URL=https://api.siliconflow.cn/v1/rerank

# Ollama compatibility fallback
OLLAMA_BASE_URL=http://localhost:11434

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_companion
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password

# App mode / API auth
APP_ENV=development
API_AUTH_TOKENS_JSON={"demo-user-token":{"user_id":"demo-user","role":"user"},"other-user-token":{"user_id":"other-user","role":"user"},"demo-admin-token":{"user_id":"demo-admin","role":"admin"}}
API_UPLOAD_MAX_FILES=5
API_UPLOAD_MAX_FILE_SIZE_MB=20
API_RATE_LIMIT_CHAT_PER_MINUTE=20
API_RATE_LIMIT_UPLOADS_PER_MINUTE=6
API_RATE_LIMIT_SYNCS_PER_MINUTE=3

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_ENABLED=true
REDIS_TTL_SECONDS=86400
SHORT_TERM_WINDOW_SIZE=8
RECENT_CONTEXT_TURNS=3

# Context compression / summarization triggers
# Primary trigger: token threshold for automatic compression of older turns.
# Tuned for 128K-context models; lower for 8K local models.
SUMMARY_TOKEN_THRESHOLD=8000
# Absolute ceiling (message count): force compression when recent history hits this.
SUMMARY_MAX_MESSAGE_CEILING=32
# Deprecated fallback: only used when SUMMARY_TOKEN_THRESHOLD=0.
SUMMARY_REFRESH_THRESHOLD=6

# Hard-trim safety net before graph invocation.
# Must leave room for system prompt + retrieved documents + user query.
# Tuned for 128K-context models; lower for 8K local models.
CONTEXT_HARD_TRIM_THRESHOLD=30000
CONTEXT_HARD_TRIM_RESERVE=4000

# Knowledge base jobs
AUTO_BOOTSTRAP_KNOWLEDGE_BASE=false
ENABLE_KB_SYNC_SCHEDULER=false
